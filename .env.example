# ─── SAHIFALAB Environment Variables ───────────────────────────────

# ─── Database ──────────────────────────────────────────────────────
POSTGRES_USER=sahifalab_user
POSTGRES_PASSWORD=sahifalab_password
POSTGRES_DB=sahifalab_db
DATABASE_URL=postgresql://sahifalab_user:sahifalab_password@postgres:5432/sahifalab_db

# ─── Backend ───────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-character-string
DEBUG=True

# ─── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Comma-separated Telegram IDs of admins  (e.g. 123456789,987654321)
ADMIN_TELEGRAM_IDS=

# ─── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── Payment providers (optional) ─────────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
